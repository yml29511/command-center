{
  "version": 1,
  "preferred_language": "zh-CN",
  "protected_branches": [
    "main",
    "master",
    "production",
    "release/*"
  ],
  "integration_mode": "merge_allowed",
  "critique": {
    "enabled": true,
    "threshold": "all_write_modes",
    "fallback_to_local_checklist": true,
    "require_user_choice_after_plan": true
  },
  "checkpoint": {
    "milestone_on_write_start": true,
    "snapshot_gate": "always_before_write",
    "archive_after_each_verified_step": true,
    "fail_close_before_write": true
  },
  "blast_radius": {
    "enabled": true,
    "required_before_write": "always",
    "script_entry": "scripts/blast-radius.py",
    "default_reverse_depth": 2,
    "max_refs_per_section": 25,
    "include_neighbor_tests": true,
    "update_current_report": true,
    "fail_close_on_unknown_target": true,
    "fail_close_on_risk_escalation": true
  },
  "testing": {
    "default_backend_tests": true,
    "gui_autorun_on_gui_task": true,
    "gui_visible_execution": "preferred",
    "gui_block_completion_until_passed": true,
    "gui_case_matrix_required": true,
    "gui_evidence_required": true,
    "gui_autofix_retry_limit": 3,
    "big_test_current_test_required": true
  },
  "logging": {
    "usage_log_enabled": false,
    "receipt_verbosity": "full"
  }
}
